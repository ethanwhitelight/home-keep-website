# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is already in .gitignore.

# --- Supabase ---
# Project Settings -> API in your Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key: server-only, bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
# Use TEST mode keys until launch. Developers -> API keys in the Stripe dashboard.
STRIPE_SECRET_KEY=
# Generated by `stripe listen` locally, or the webhook endpoint's signing secret in production.
STRIPE_WEBHOOK_SECRET=
# Price IDs for each annual membership tier (Products -> Pricing in the Stripe dashboard).
STRIPE_PRICE_SILVER=
STRIPE_PRICE_GOLD=
STRIPE_PRICE_PLATINUM=

# --- Email (stubbed, TODO: wire up before launch) ---
RESEND_API_KEY=
