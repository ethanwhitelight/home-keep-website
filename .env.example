# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is already in .gitignore.

# --- Supabase ---
# Project Settings -> API in your Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key: server-only, bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
# IMPORTANT: the secret key and webhook secret must be the SAME MODE as the
# Payment Links in src/lib/stripe/paymentLinks.ts. Those are now LIVE-mode links,
# so production must use LIVE-mode values here. Mixing modes silently breaks the
# flow: live checkouts emit live events that fail verification against a test
# webhook secret, so the customer is charged but their membership never activates.
#
# Secret key: Developers -> API keys (use the "sk_live_..." key in production).
STRIPE_SECRET_KEY=
# Webhook signing secret ("whsec_..."). Locally this comes from `stripe listen`;
# in production, copy it from the LIVE webhook endpoint under Developers -> Webhooks.
# Test-mode `stripe listen` secrets will NOT verify live Payment Link events.
STRIPE_WEBHOOK_SECRET=
# Per-tier Payment Link URLs live in src/lib/stripe/paymentLinks.ts (not env vars)
# since they're public, stable URLs rather than secrets.

# --- Email (stubbed, TODO: wire up before launch) ---
RESEND_API_KEY=

# --- Site ---
# TODO(confirm): real production domain once decided. Used by sitemap.xml/robots.txt.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
