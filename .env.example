# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is already in .gitignore.

# --- Supabase ---
# Project Settings -> API in your Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key: server-only, bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
# Use TEST mode keys until launch. Developers -> API keys in the Stripe dashboard.
STRIPE_SECRET_KEY=
# Generated by `stripe listen` locally, or the webhook endpoint's signing secret in production.
STRIPE_WEBHOOK_SECRET=
# Per-tier Payment Link URLs live in src/lib/stripe/paymentLinks.ts (not env vars)
# since they're public, stable URLs rather than secrets.

# --- Email (stubbed, TODO: wire up before launch) ---
RESEND_API_KEY=

# --- Site ---
# TODO(confirm): real production domain once decided. Used by sitemap.xml/robots.txt.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
